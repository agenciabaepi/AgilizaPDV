{
  "name": "agiliza-pdv",
  "version": "0.1.18",
  "description": "PDV Desktop - Agiliza",
  "main": "./out/main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:store-server": "npm --prefix store-server run build",
    "build:all": "npm run build:store-server && npm run build",
    "check:embedded-postgres": "node scripts/windows/check-embedded-postgres.cjs",
    "build:win": "npm run check:embedded-postgres && npm run build:all && electron-builder --win --config --publish never",
    "release:windows:next": "node scripts/windows/release-next-steps.cjs",
    "build:win:localtest": "npm run build:win && npm run release:windows:next",
    "build:mac": "npm run build:all && electron-builder --mac --config --publish never",
    "build:linux": "npm run build:all && electron-builder --linux --config --publish never",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild",
    "seed": "node scripts/seed-test-user.cjs",
    "homologacao:checklist": "echo \"Veja docs/windows-homologacao-servidor-terminal.md\"",
    "go-live:checklist": "echo \"Veja docs/windows-go-live-checklist.md\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "better-sqlite3": "^12.6.2",
    "bonjour-service": "^1.3.0",
    "dotenv": "^17.3.1",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.576.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0"
  }
}
