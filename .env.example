# Copie para .env e preencha com os dados do seu projeto Supabase
# Supabase > Project Settings > API

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-public

# Desenvolvimento (npm run dev): força uso do SQLite local e ignora serverUrl do agiliza-pdv-config.json
# quando você não tem o store-server rodando (ex.: Mac). Valores aceitos: 1, true, yes
# AGILIZA_PDV_USE_LOCAL_DB=1

# Simula modo instalação Windows no dev (badge Login / WebSocket / API terminais). Valores: server | terminal
# AGILIZA_INSTALL_MODE=server
